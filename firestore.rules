rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Mode test: izinkan semua read/write selama 30 hari
    // GANTI dengan rules yang lebih ketat sebelum production!
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 7, 14);
    }
  }
}
